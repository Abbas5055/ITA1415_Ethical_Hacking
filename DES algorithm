import numpy as np

def des_encrypt():
    IP = [2, 6, 3, 1, 4, 8, 5, 7] 
    
    pt_input = input("Enter 8-character binary plaintext ")
    pt = np.array([int(b) for b in pt_input])
    
    permuted_pt = pt[np.array(IP) - 1]
    
    L, R = np.split(permuted_pt, 2)
    
    print(f"Initial Permutation: {permuted_pt}")
    print(f"Left Half:  {L}")
    print(f"Right Half: {R}")
    
    

if __name__ == "__main__":
    des_encrypt()
